SUPABASE_PASS=projectlinkcho2
SUPABASE_ACCESS_TOKEN=sbp_4f81055b87b0f83aa748dec88ddd2d1feb75d2ef

# ============================================================
# Project LINK — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# SUPABASE
# Dashboard → Project Settings → API
# ------------------------------------------------------------

# Project URL (used by both frontend and backend)
SUPABASE_URL=https://jwpdlkqxsohmdaveuali.supabase.co

# Anon/public key — safe to expose in the frontend (RLS enforces access)
SUPABASE_ANON_KEY=

# Service role key — BACKEND ONLY. Has full DB access, bypasses RLS.
# Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used by FastAPI to verify Supabase-issued tokens
# Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=


# ------------------------------------------------------------
# DATABASE (Direct Postgres connection for FastAPI / migrations)
# Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL for the API, "Session" for migrations.
# ------------------------------------------------------------

DATABASE_URL=postgresql://postgres.jwpdlkqxsohmdaveuali:[${SUPABASE_PASS}]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Pooler URL (Transaction mode — for the FastAPI app)
DATABASE_POOL_URL=postgresql://postgres.jwpdlkqxsohmdaveuali:[${SUPABASE_PASS}]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres


# ------------------------------------------------------------
# FASTAPI (Backend)
# ------------------------------------------------------------

# Environment: development | staging | production
APP_ENV=development

# Secret key for signing internal tokens (generate with: openssl rand -hex 32)
APP_SECRET_KEY=

# Port the FastAPI server listens on
APP_PORT=8000

# Comma-separated list of allowed CORS origins
# Example: https://your-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173


# ------------------------------------------------------------
# REDIS (Celery broker & result backend)
# DigitalOcean → Managed Redis → Connection Details
# ------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# Celery-specific (can mirror REDIS_URL or use separate DBs)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# ------------------------------------------------------------
# SUPABASE STORAGE
# Bucket name for exported M1/M2/Q1/A1 report files
# Dashboard → Storage → Create bucket named "reports"
# ------------------------------------------------------------

SUPABASE_STORAGE_REPORTS_BUCKET=reports


# ------------------------------------------------------------
# FRONTEND (Vite — VITE_ prefix required for browser exposure)
# These go in frontend/.env or are set in Vercel project settings.
# ------------------------------------------------------------

# Supabase public-facing values (safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# FastAPI base URL consumed by the frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# MapTiler API key for MapLibre GL JS tile rendering
# https://cloud.maptiler.com/account/keys
VITE_MAPTILER_API_KEY=


# ------------------------------------------------------------
# ML / ANALYTICS (Backend — Celery beat scheduler)
# ------------------------------------------------------------

# How often to retrain ML models (cron expression)
ML_RETRAIN_SCHEDULE=0 2 1 * *   # 2 AM on the 1st of each month

# Path inside the container where serialized .pkl models are stored
ML_MODEL_DIR=/app/ml/models
